# mPAPA — Example Environment Configuration
# Copy this file to .env and adjust values as needed.
# All variables use the PATENT_ prefix.

# --- LM Studio Connection ---
PATENT_LM_STUDIO_BASE_URL=http://localhost:1234/v1
PATENT_LM_STUDIO_API_KEY=not-needed

# --- Model Assignments (per agent task) ---
# Set these to the model name loaded in LM Studio.
# Use "default" to let LM Studio pick the active model.
PATENT_MODEL_DISCLOSURE=default
PATENT_MODEL_SEARCH=default
PATENT_MODEL_CLAIMS=default
PATENT_MODEL_DESCRIPTION=default
PATENT_MODEL_REVIEW=default
PATENT_MODEL_CHAT=default

# --- Embedding ---
# Model name as loaded in LM Studio (used for /v1/embeddings endpoint)
PATENT_EMBEDDING_MODEL_NAME=text-embedding-nomic-embed-text-v1.5

# --- Database ---
PATENT_DATABASE_PATH=data/patent_system.db

# --- DOCX Export ---
# Directory containing .docx template files
PATENT_DOCX_TEMPLATE_DIR=src/patent_system/export/templates
# Template filename (leave empty for blank document)
# PATENT_DOCX_TEMPLATE_NAME=european_patent.docx
PATENT_DOCX_TEMPLATE_NAME=template.docx

# --- Monitoring ---
# Hours between background prior art search cycles
PATENT_MONITORING_INTERVAL_HOURS=24

# --- Search ---
# Maximum number of results to fetch per source (ArXiv, PubMed, etc.)
PATENT_SEARCH_MAX_RESULTS_PER_SOURCE=10
# Seconds to wait between requests to the same source (rate limiting)
PATENT_SEARCH_REQUEST_DELAY_SECONDS=3.0
# Maximum documents to score for relevance
PATENT_SEARCH_RELEVANCE_TOP_K=200

# --- Full-Text Download & Vectorization ---
# Enable/disable full-text download during prior art searches (true/false)
PATENT_FULL_TEXT_DOWNLOAD_ENABLED=true
# Character limit for text sent to embedding and RAG indexing pipelines
PATENT_VECTORIZATION_TEXT_LIMIT=4000
# Directory for storing downloaded PDF files (relative to base dir or absolute)
PATENT_PDF_DOWNLOAD_DIR=data/pdfs

# --- EPO Open Patent Services (OPS) ---
# Register at https://developers.epo.org/ to get API credentials
PATENT_EPO_OPS_KEY=
PATENT_EPO_OPS_SECRET=

# --- Logging ---
PATENT_LOG_FILE_PATH=logs/patent_system.log
# Options: DEBUG, INFO, WARNING, ERROR
PATENT_LOG_LEVEL=INFO

# --- Web Server ---
PATENT_NICEGUI_PORT=8080
# Set to true for auto-reload on file changes during development
PATENT_NICEGUI_RELOAD=false
